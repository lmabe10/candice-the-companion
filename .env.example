# Local development only — copy to .dev.vars for `npm run pages:dev`
RESEND_API_KEY=re_your_api_key_here
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=Candice the Companion <onboarding@resend.dev>

# Production setup:
# 1. Edit CONTACT_TO_EMAIL and CONTACT_FROM_EMAIL in wrangler.toml, then commit & push.
# 2. Add RESEND_API_KEY as a Secret in Cloudflare Dashboard (or via CLI below).
#
# CLI alternative for the secret:
#   npx wrangler pages secret put RESEND_API_KEY --project-name=candice-the-companion
